model OrgInvite {
  id          String    @id @default(cuid())
  orgId       String
  email       String
  token       String    @unique @default(cuid())
  role        OrganisationRole @default(MEMBER)
  createdById String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  org       Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User         @relation("CreatedOrgInvites", fields: [createdById], references: [id])
}

model ActivityEvent {
  id             String        @id @default(cuid())
  projectId      String?
  organisationId String?
  userId         String
  type           String
  payload        Json?
  createdAt      DateTime      @default(now())

  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organisation Organisation? @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user         User          @relation("ActivityEvents", fields: [userId], references: [id])

  @@index([organisationId])
}

model FundingCampaign {
  id                     String    @id @default(cuid())
  projectId              String    @unique
  title                  String
  description            String?
  goal                   Int
  currency               String    @default("SEK")
  status                 String    @default("active")
  campaignType           String    @default("donation") // "donation" | "reward" | "token"
  tokenExchangeRate      Float?    // e.g. 100 -> "100 SEK = 1 Tribe Token"; only meaningful when campaignType == "token"
  deadline               DateTime?
  platformFee            Float     @default(5)
  stripeAccountId        String?
  stripeOnboardingStatus String    @default("not_started") // "not_started" | "pending" | "complete", driven by the account.updated webhook
  createdAt              DateTime  @default(now())

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pledges     FundingPledge[]
  rewardTiers FundingRewardTier[]
  expenses    FundingExpense[]
}

model FundingPledge {
  id                String   @id @default(cuid())
  campaignId        String
  userId            String
  amount            Int
  message           String?
  stripeSessionId   String?  @unique
  pledgeStatus      String   @default("confirmed")
  rewardTierId      String?
  paymentMethodType String?  // mirrors PaymentIntent.payment_method_types[0], e.g. "card" | "klarna" | "bancontact"
  tokenLedgerId     String?  @unique
  createdAt         DateTime @default(now())

  campaign    FundingCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user        User               @relation("FundingPledges", fields: [userId], references: [id], onDelete: Cascade)
  rewardTier  FundingRewardTier? @relation(fields: [rewardTierId], references: [id], onDelete: SetNull)
  tokenLedger TokenLedger?       @relation("PledgeTokenMint", fields: [tokenLedgerId], references: [id], onDelete: SetNull)

  @@index([campaignId, userId])
}

model CalendarEvent {
  id          String    @id @default(cuid())
  projectSlug String
  project     Project   @relation("ProjectCalendarEvents", fields: [projectSlug], references: [slug], onDelete: Cascade)
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime?
  type        String    @default("custom")
  createdById String
  createdBy   User      @relation("CreatedCalendarEvents", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  @@index([projectSlug, startsAt])
}

model TaskEstimate {
  id           String     @id @default(cuid())
  kanbanCardId String     @unique
  kanbanCard   KanbanCard @relation(fields: [kanbanCardId], references: [id], onDelete: Cascade)
  aiHours      Float
  aiConfidence String
  aiReasoning  String     @db.Text
  manualHours  Float?
  lockedAt     DateTime?
  createdAt    DateTime   @default(now())
}


model TokenLedger {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation("TokenLedger", fields: [userId], references: [id])
  projectSlug  String
  project      Project     @relation("ProjectTokenLedger", fields: [projectSlug], references: [slug])
  kanbanCardId String?
  kanbanCard   KanbanCard? @relation("KanbanTokens", fields: [kanbanCardId], references: [id], onDelete: SetNull)
  tokens       Float
  reason       String
  createdAt    DateTime    @default(now())
  gtMirrors    GtLedger[]  @relation("GtLedgerSource")
  pledgeMint   FundingPledge? @relation("PledgeTokenMint")

  @@index([userId])
  @@index([projectSlug])
}

model KanbanCardPriorityChange {
  id           String     @id @default(cuid())
  kanbanCardId String
  kanbanCard   KanbanCard @relation(fields: [kanbanCardId], references: [id], onDelete: Cascade)
  changedById  String
  changedBy    User       @relation("PriorityChanges", fields: [changedById], references: [id])
  fromPriority String
  toPriority   String
  changedAt    DateTime   @default(now())

  @@index([kanbanCardId])
}

model GtLedger {
  id                  String       @id @default(cuid())
  userId              String
  user                User         @relation("GtLedger", fields: [userId], references: [id])
  tokens              Float
  sourceTokenLedgerId String?
  sourceTokenLedger   TokenLedger? @relation("GtLedgerSource", fields: [sourceTokenLedgerId], references: [id], onDelete: SetNull)
  reason              String
  createdAt           DateTime     @default(now())

  @@index([userId])
}

model AiTaskRun {
  id             String         @id @default(cuid())
  kanbanCardId   String
  kanbanCard     KanbanCard     @relation("KanbanAiRuns", fields: [kanbanCardId], references: [id], onDelete: Cascade)
  agentType      String
  status         String         @default("running")
  outputMarkdown String?        @db.Text
  attemptNumber  Int            @default(1)
  feedback       String?        @db.Text
  createdAt      DateTime       @default(now())
  completedAt    DateTime?
  reviews        AiTaskReview[]

  @@index([kanbanCardId])
}

model AiTaskReview {
  id            String    @id @default(cuid())
  aiTaskRunId   String
  aiTaskRun     AiTaskRun @relation(fields: [aiTaskRunId], references: [id], onDelete: Cascade)
  reviewerId    String
  reviewer      User      @relation("AiTaskReviews", fields: [reviewerId], references: [id])
  decision      String
  feedback      String?   @db.Text
  tokensAwarded Float?
  createdAt     DateTime  @default(now())
}

model Poll {
  id            String       @id @default(cuid())
  projectSlug   String
  project       Project      @relation("ProjectPolls", fields: [projectSlug], references: [slug], onDelete: Cascade)
  createdById   String
  createdBy     User         @relation("CreatedPolls", fields: [createdById], references: [id])
  title         String
  description   String?      @db.Text
  type          String       @default("yes_no")
  status        String       @default("open")
  visibility    String       @default("live")
  isBinding     Boolean      @default(false)
  quorumPercent Float?
  deadline      DateTime?
  closedAt      DateTime?
  createdAt     DateTime     @default(now())
  options       PollOption[]
  votes         PollVote[]

  @@index([projectSlug])
}

model PollOption {
  id          String     @id @default(cuid())
  pollId      String
  poll        Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label       String
  description String?
  sortOrder   Int        @default(0)
  votes       PollVote[]
}

model PollVote {
  id           String     @id @default(cuid())
  pollId       String
  poll         Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollOptionId String
  pollOption   PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation("UserPollVotes", fields: [userId], references: [id])
  tokenWeight  Float
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([pollId, pollOptionId, userId])
  @@index([pollId, userId])
}

// The Foundation-owned umbrella AB(s) a commercial_umbrella project's
// product line sits under (PRD 4c), e.g. "GoodTribes Ventures AB".
model CommercialUmbrellaEntity {
  id                    String   @id @default(cuid())
  name                  String
  foundationAbOrgNumber String?
  createdAt             DateTime @default(now())

  projects Project[]
}

// PRD 4c "Övergång mellan juridisk form": a member-initiated request,
// decided by a Tribe-Token-weighted Poll (see closePoll's legal_type_change
// branch in polls/actions.ts), but only ever executed by the Foundation
// (site-admin) — an approved vote is a request, never an automatic change.
model LegalTypeChangeRequest {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedType LegalType
  pollId        String?
  status        String    @default("pending") // pending | approved_by_members | rejected_by_members | executed | rejected_by_foundation
  requestedById String
  requestedBy   User      @relation("RequestedLegalTypeChanges", fields: [requestedById], references: [id])
  decisionNote  String?   @db.Text
  executedById  String?
  executedBy    User?     @relation("ExecutedLegalTypeChanges", fields: [executedById], references: [id], onDelete: SetNull)
  executedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([projectId])
}

// PRD 4a Intäktsström 2 / Utvecklingsfas 2.96, Steg 1: the board's ("styrelsen",
// represented by site-admin) proposed split of a commercial project's audited
// profit between Stiftelsens drift and the Impact-fond, decided by a
// Tribe-Token-weighted Poll (closePoll's profit_distribution branch), and only
// ever executed (or vetoed) by the Foundation — same request/vote/execute shape
// as LegalTypeChangeRequest above.
model ProfitDistributionProposal {
  id                    String    @id @default(cuid())
  projectId             String
  project               Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  auditedProfitSek      Int
  proposedOperationsPct Float
  proposedImpactFundPct Float
  pollId                String?
  status                String    @default("pending") // pending | approved_by_members | rejected_by_members | vetoed_by_foundation | executed
  proposedById          String
  proposedBy            User      @relation("ProposedProfitDistributions", fields: [proposedById], references: [id])
  decisionNote          String?   @db.Text
  executedById          String?
  executedBy            User?     @relation("ExecutedProfitDistributions", fields: [executedById], references: [id], onDelete: SetNull)
  executedAt            DateTime?
  createdAt             DateTime  @default(now())

  distribution ProfitDistribution?

  @@index([projectId])
}

// The executed record of Steg 1 once the Foundation approves a proposal —
// splits the audited profit into the three shares PRD 4a describes.
model ProfitDistribution {
  id                 String   @id @default(cuid())
  proposalId         String   @unique
  proposal           ProfitDistributionProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  auditedProfitSek   Int
  operationsShareSek Int
  impactFundShareSek Int
  remainingShareSek  Int
  createdAt          DateTime @default(now())

  allocations PersonalProfitAllocation[]

  @@index([projectId])
}

// PRD 4a Intäktsström 2, Steg 2: each Tribe Token holder's personal share of
// remainingShareSek, proportional to their TokenLedger balance in the
// distributing project. A personal choice, not a vote — targetProjectSlug is
// null until the holder picks a recipient project, and stays null if the
// deadline sweep (see /api/cron/impact-fund-sweep) defaults it to the fund.
model PersonalProfitAllocation {
  id                 String    @id @default(cuid())
  distributionId     String
  distribution       ProfitDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountAvailableSek Int
  allocationDeadline DateTime
  targetProjectSlug  String?
  processedAt        DateTime?
  createdAt          DateTime  @default(now())

  @@index([userId])
  @@index([distributionId])
}

// PRD 5.52: the Impact-fond's full inflow/outflow history — always real SEK,
// never a token transaction (see Utvecklingsfas 2.96's grundprincip). Money
// movement here is admin-attested (no Stripe Connect exists yet), not an
// automatic transfer — every row is a real, auditable fact for the public
// transparency page (PRD 5.51), recorded by whoever attested the movement.
model ImpactFundLedger {
  id                    String   @id @default(cuid())
  direction             String   // "in" | "out"
  amountSek             Int
  relatedDistributionId String?
  relatedAllocationId   String?
  targetProjectId       String?
  targetProject         Project? @relation("ImpactFundPayouts", fields: [targetProjectId], references: [id], onDelete: SetNull)
  decidedByPollId       String?
  note                  String?  @db.Text
  recordedById          String?
  recordedBy            User?    @relation("RecordedImpactFundEntries", fields: [recordedById], references: [id], onDelete: SetNull)
  createdAt             DateTime @default(now())
}

// PRD 5.50.4: a round of the Impact-fond's outbound allocation to new
// projects, decided by a platform-wide GT-weighted vote (PlatformPoll, type
// "impact_fund_allocation") over site-admin-nominated candidate projects —
// same election mechanics as Granskningsrådet, reused for a different type.
model ImpactFundAllocationRound {
  id         String    @id @default(cuid())
  pollId     String    @unique
  status     String    @default("open") // open | closed | executed
  openedById String
  openedBy   User      @relation("OpenedImpactFundRounds", fields: [openedById], references: [id])
  executedAt DateTime?
  createdAt  DateTime  @default(now())
}

// Platform-wide, GT-weighted polls (Granskningsrådet elections, PRD 5.53;
// room for future platform-level votes e.g. Impact-fund priority, Fas 2.96).
// Deliberately separate from Poll/PollOption/PollVote, which are always
// project-scoped (Poll.projectSlug is a required FK) — see PRD 4d note.
model PlatformPoll {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  type        String    @default("council_election")
  status      String    @default("open")
  seatCount   Int?
  termMonths  Int?
  deadline    DateTime?
  closedAt    DateTime?
  createdById String
  createdBy   User      @relation("CreatedPlatformPolls", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  options PlatformPollOption[]
  votes   PlatformPollVote[]
}

model PlatformPollOption {
  id              String       @id @default(cuid())
  pollId          String
  poll            PlatformPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  candidateId     String?
  candidate       User?        @relation("PlatformPollCandidacies", fields: [candidateId], references: [id], onDelete: Cascade)
  // Set when this option is a candidate project in an Impact-fund
  // allocation round (PRD 5.50.4) rather than a council-election candidate.
  linkedProjectId String?
  linkedProject   Project?     @relation("ImpactFundPollOptionProjects", fields: [linkedProjectId], references: [id], onDelete: Cascade)
  label           String
  description     String?
  sortOrder       Int          @default(0)

  votes PlatformPollVote[]
}

model PlatformPollVote {
  id           String             @id @default(cuid())
  pollId       String
  poll         PlatformPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollOptionId String
  pollOption   PlatformPollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)
  userId       String
  user         User               @relation("PlatformPollVotes", fields: [userId], references: [id])
  gtWeight     Float
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([pollId, pollOptionId, userId])
  @@index([pollId, userId])
}

model ReviewCouncilMember {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation("ReviewCouncilMemberships", fields: [userId], references: [id], onDelete: Cascade)
  termStart        DateTime @default(now())
  termEnd          DateTime
  electedViaPollId String?
  createdAt        DateTime @default(now())

  @@index([userId])
}

// Granskningsrådet's uteslutningsärenden (PRD 5.53-5.55) — deliberately
// separate from ContentFlag/EthicsReview (which stay reviewer=site-admin/
// council for flagged *projects*, see canReviewEthicsFlags): reporting a
// *user* for misconduct needs richer state (project scope, response window,
// proposed decision, council votes) than the generic flag pipeline has.
model ExclusionCase {
  id                String    @id @default(cuid())
  reportedUserId    String
  reportedUser      User      @relation("ReportedInExclusionCases", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reportedById      String
  reportedBy        User      @relation("FiledExclusionCases", fields: [reportedById], references: [id])
  projectId         String?
  project           Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  reason            String    @db.Text
  responseText      String?   @db.Text
  respondedAt       DateTime?
  status            String    @default("open")
  proposedDecision  String?
  decision          String?
  decidedAt         DateTime?
  decisionReasoning String?   @db.Text
  createdAt         DateTime  @default(now())

  votes ExclusionCaseVote[]
  @@index([reportedUserId])
  @@index([projectId])
}

model ExclusionCaseVote {
  id              String        @id @default(cuid())
  caseId          String
  case            ExclusionCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  councilMemberId String
  councilMember   User          @relation("ExclusionCaseVotes", fields: [councilMemberId], references: [id])
  vote            String
  reasoning       String?       @db.Text
  createdAt       DateTime      @default(now())

  @@unique([caseId, councilMemberId])
}

model FundingRewardTier {
  id          String          @id @default(cuid())
  campaignId  String
  campaign    FundingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  title       String
  description String?
  minAmount   Int
  maxBackers  Int?
  sortOrder   Int             @default(0)
  pledges     FundingPledge[]
  createdAt   DateTime        @default(now())

  @@index([campaignId])
}

model FundingExpense {
  id          String          @id @default(cuid())
  campaignId  String
  campaign    FundingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  title       String
  amount      Int
  description String?
  receiptUrl  String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  milestoneId String?
  milestone   Milestone?      @relation("ExpenseMilestone", fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([milestoneId])
}

// PRD 5.68 — a project<->organisation sponsor/partner/supporter link. Requires
// symmetric consent: whichever side didn't propose it must accept before
// status flips to "active" and it becomes publicly visible / usable for
// matchmaking exclusion (see proposePartnership/respondToPartnership in
// lib/actions/partnerships.ts). Either side can revoke unilaterally once
// active — same leave-anytime spirit as OrganisationMember/ProjectMember.
model Partnership {
  id             String    @id @default(cuid())
  projectId      String
  organisationId String
  type           String    @default("partner") // "sponsor" | "partner" | "supporter"
  description    String?
  status         String    @default("pending")  // "pending" | "active" | "declined" | "revoked"
  proposedBy     String    // "org" | "project" — who initiated, so the initiator can't also accept
  initiatedById  String
  respondedById  String?
  respondedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project      Project      @relation("ProjectPartnerships", fields: [projectId], references: [id], onDelete: Cascade)
  organisation Organisation @relation("OrganisationPartnerships", fields: [organisationId], references: [id], onDelete: Cascade)
  initiatedBy  User         @relation("PartnershipInitiatedBy", fields: [initiatedById], references: [id])
  respondedBy  User?        @relation("PartnershipRespondedBy", fields: [respondedById], references: [id])

  @@unique([projectId, organisationId])
  @@index([organisationId])
  @@index([projectId])
}

model ImpactMetric {
  id           String         @id @default(cuid())
  projectSlug  String
  project      Project        @relation("ProjectImpactMetrics", fields: [projectSlug], references: [slug], onDelete: Cascade)
  label        String
  unit         String
  targetValue  Float?
  currentValue Float          @default(0)
  description  String?
  updates      ImpactUpdate[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([projectSlug])
}

model ImpactUpdate {
  id             String       @id @default(cuid())
  impactMetricId String
  impactMetric   ImpactMetric @relation(fields: [impactMetricId], references: [id], onDelete: Cascade)
  value          Float
  note           String?
  updatedById    String
  updatedBy      User         @relation("ImpactUpdates", fields: [updatedById], references: [id])
  createdAt      DateTime     @default(now())

  @@index([impactMetricId])
}

model ProjectMaturity {
  id               String    @id @default(cuid())
  projectSlug      String    @unique
  project          Project   @relation("ProjectMaturity", fields: [projectSlug], references: [slug], onDelete: Cascade)
  score            Int       @default(0)
  scoreBreakdown   Json?
  scaleInitiatedAt DateTime?
  scalingPlan      String?   @db.Text
  finalReport      String?   @db.Text
  calculatedAt     DateTime  @default(now())
}

model LeanCanvas {
  id                     String    @id @default(cuid())
  projectSlug            String    @unique
  project                Project   @relation("ProjectLeanCanvas", fields: [projectSlug], references: [slug], onDelete: Cascade)
  problem                String?   @db.Text
  alternatives           String?   @db.Text
  customerSegments       String?   @db.Text
  earlyAdopters          String?   @db.Text
  uniqueValueProposition String?   @db.Text
  concept                String?   @db.Text
  solution               String?   @db.Text
  channels               String?   @db.Text
  revenueStreams         String?   @db.Text
  costStructure          String?   @db.Text
  impact                 String?   @db.Text
  keyMetrics             String?   @db.Text
  unfairAdvantage        String?   @db.Text
  updatedById            String?
  updatedBy              User?     @relation("LeanCanvasUpdatedBy", fields: [updatedById], references: [id])
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model LeanCanvasComment {
  id           String   @id @default(cuid())
  projectSlug  String
  project      Project  @relation("ProjectLeanCanvasComments", fields: [projectSlug], references: [slug], onDelete: Cascade)
  authorId     String
  author       User     @relation("LeanCanvasCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body         String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  hiddenAt     DateTime?
  hiddenById   String?
  hiddenReason ContentHideReason?

  @@index([projectSlug])
}

model ProjectInstance {
  id           String   @id @default(cuid())
  parentSlug   String
  parent       Project  @relation("ParentInstances", fields: [parentSlug], references: [slug], onDelete: Cascade)
  childSlug    String   @unique
  child        Project  @relation("ChildInstance", fields: [childSlug], references: [slug], onDelete: Cascade)
  region       String
  country      String?  // free text, normalized via lib/geo.ts same as User.country — powers the network dashboard's world map
  status       String   @default("pending")
  approvedById String?
  approvedBy   User?    @relation("ApprovedInstances", fields: [approvedById], references: [id])
  createdAt    DateTime @default(now())

  @@unique([parentSlug, childSlug])
}

model ProjectAlumni {
  id            String   @id @default(cuid())
  projectSlug   String
  project       Project  @relation("ProjectAlumni", fields: [projectSlug], references: [slug], onDelete: Cascade)
  userId        String
  user          User     @relation("AlumniUsers", fields: [userId], references: [id])
  tokensEarned  Float    @default(0)
  badgeIssuedAt DateTime @default(now())
  finalReport   String?  @db.Text

  @@unique([projectSlug, userId])
  @@index([projectSlug])
}

model Mentor {
  id         String              @id @default(cuid())
  userId     String              @unique
  user       User                @relation("MentorProfile", fields: [userId], references: [id], onDelete: Cascade)
  categories String[]
  bio        String?
  verified   Boolean             @default(false)
  requests   MentorshipRequest[]
  createdAt  DateTime            @default(now())
}

model MentorshipRequest {
  id            String              @id @default(cuid())
  projectId     String
  project       Project             @relation("ProjectMentorships", fields: [projectId], references: [id], onDelete: Cascade)
  mentorId      String
  mentor        Mentor              @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  status        String              @default("pending")
  message       String?
  sessionAt     DateTime?
  tokensAwarded Float?
  feedback      MentorshipFeedback?
  createdAt     DateTime            @default(now())

  @@index([projectId])
  @@index([mentorId])
}

model MentorshipFeedback {
  id                  String            @id @default(cuid())
  mentorshipRequestId String            @unique
  mentorshipRequest   MentorshipRequest @relation(fields: [mentorshipRequestId], references: [id], onDelete: Cascade)
  rating              Int
  comment             String?
  createdAt           DateTime          @default(now())
}

model AcademyGuide {
  id              String                @id @default(cuid())
  title           String
  bodyMarkdown    String                @db.Text
  category        String
  authorId        String
  author          User                  @relation("GuideAuthor", fields: [authorId], references: [id])
  reviewedById    String?
  reviewedBy      User?                 @relation("GuideReviewer", fields: [reviewedById], references: [id])
  difficulty      String                @default("beginner")
  readTimeMinutes Int                   @default(5)
  published       Boolean               @default(false)
  completions     UserGuideCompletion[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  hiddenAt        DateTime?
  hiddenById      String?
  hiddenReason    ContentHideReason?

  @@index([category])
}

model UserGuideCompletion {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation("GuideCompletions", fields: [userId], references: [id], onDelete: Cascade)
  guideId     String
  guide       AcademyGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)
  completedAt DateTime     @default(now())

  @@unique([userId, guideId])
}

model Kudos {
  id         String   @id @default(cuid())
  fromUserId String
  fromUser   User     @relation("KudosSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User     @relation("KudosReceived", fields: [toUserId], references: [id], onDelete: Cascade)
  projectId  String?
  project    Project? @relation("ProjectKudos", fields: [projectId], references: [id], onDelete: SetNull)
  message    String
  createdAt  DateTime @default(now())

  @@index([toUserId])
}

model UserStreak {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation("UserStreaks", fields: [userId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project  @relation("ProjectStreaks", fields: [projectId], references: [id], onDelete: Cascade)
  currentWeeks   Int      @default(0)
  longestWeeks   Int      @default(0)
  lastActivityAt DateTime @default(now())

  @@unique([userId, projectId])
}

model DreamWallPost {
  id           String              @id @default(cuid())
  userId       String
  user         User                @relation("DreamPosts", fields: [userId], references: [id], onDelete: Cascade)
  dreamText    String
  reactions    DreamWallReaction[]
  createdAt    DateTime            @default(now())
  hiddenAt     DateTime?
  hiddenById   String?
  hiddenReason ContentHideReason?
}

model DreamWallReaction {
  id              String        @id @default(cuid())
  dreamWallPostId String
  dreamWallPost   DreamWallPost @relation(fields: [dreamWallPostId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation("DreamReactions", fields: [userId], references: [id], onDelete: Cascade)
  emoji           String
  createdAt       DateTime      @default(now())

  @@unique([dreamWallPostId, userId, emoji])
}

model ProjectFlag {
  id           String        @id @default(cuid())
  projectId    String
  project      Project       @relation("ProjectFlags", fields: [projectId], references: [id], onDelete: Cascade)
  flaggedById  String
  flaggedBy    User          @relation("FlaggedBy", fields: [flaggedById], references: [id])
  reason       String
  status       String        @default("pending")
  reviewedById String?
  reviewedBy   User?         @relation("FlagReviewer", fields: [reviewedById], references: [id])
  decisionNote String?
  ethicsReview EthicsReview?
  createdAt    DateTime      @default(now())

  @@index([projectId])
}

model EthicsReview {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation("EthicsReviews", fields: [projectId], references: [id], onDelete: Cascade)
  reviewerId    String
  reviewer      User         @relation("EthicsReviewer", fields: [reviewerId], references: [id])
  projectFlagId String?      @unique
  projectFlag   ProjectFlag? @relation(fields: [projectFlagId], references: [id])
  contentFlagId String?      @unique
  contentFlag   ContentFlag? @relation("ProjectContentFlagEthicsReview", fields: [contentFlagId], references: [id])
  outcome       String
  note          String?
  createdAt     DateTime     @default(now())

  @@index([projectId])
}

// Generic moderation flag for individual comments/posts/messages, as opposed
// to ProjectFlag/OrganisationFlag which flag an entire project/org and drive
// a dedicated ethics-review workflow. targetType/targetId is the same loose
// union pairing FeedComment/FeedLike already use.
model ContentFlag {
  id           String     @id @default(cuid())
  targetType   String
  targetId     String
  flaggedById  String
  flaggedBy    User       @relation("ContentFlaggedBy", fields: [flaggedById], references: [id], onDelete: Cascade)
  reason       FlagReason
  note         String?
  status       FlagStatus @default(PENDING)
  reviewedById String?
  reviewedBy   User?      @relation("ContentFlagReviewer", fields: [reviewedById], references: [id])
  decisionNote String?
  createdAt    DateTime   @default(now())
  reviewedAt   DateTime?

  ethicsReview    EthicsReview?             @relation("ProjectContentFlagEthicsReview")
  orgEthicsReview OrganisationEthicsReview? @relation("OrgContentFlagEthicsReview")

  @@unique([targetType, targetId, flaggedById])
  @@index([targetType, targetId])
  @@index([status])
}

enum RoomType {
  DM
  GROUP
  PROJECT_CHANNEL
  ORG_CHANNEL
  IDEA_THREAD
}

enum RoomPostingPolicy {
  ALL_MEMBERS
  LEADS_ONLY
}

enum RoomParticipantRole {
  OWNER
  ADMIN
  MEMBER
}

model Room {
  id             String            @id @default(cuid())
  type           RoomType
  name           String?
  description    String?
  pairKey        String?           @unique
  projectId      String?
  project        Project?          @relation("ProjectRooms", fields: [projectId], references: [id], onDelete: Cascade)
  organisationId String?
  organisation   Organisation?     @relation("OrgRooms", fields: [organisationId], references: [id], onDelete: Cascade)
  postingPolicy  RoomPostingPolicy @default(ALL_MEMBERS)
  order          Int               @default(0)
  pinned         Boolean           @default(false)
  createdAt      DateTime          @default(now())
  lastMessageAt  DateTime          @default(now())

  convertedToIdeaId    String?  @unique
  convertedToIdea      Idea?    @relation("RoomConvertedToIdea", fields: [convertedToIdeaId], references: [id], onDelete: SetNull)
  convertedToProjectId String?  @unique
  convertedToProject   Project? @relation("RoomConvertedToProject", fields: [convertedToProjectId], references: [id], onDelete: SetNull)

  participants RoomParticipant[]
  messages     Message[]

  @@unique([projectId, name])
  @@unique([organisationId, name])
  @@index([projectId])
  @@index([organisationId])
  @@index([lastMessageAt])
}

model RoomParticipant {
  id         String              @id @default(cuid())
  roomId     String
  room       Room                @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId     String
  user       User                @relation("RoomParticipant", fields: [userId], references: [id], onDelete: Cascade)
  role       RoomParticipantRole @default(MEMBER)
  lastReadAt DateTime            @default(now())
  createdAt  DateTime            @default(now())

  @@unique([roomId, userId])
  @@index([userId])
}

model Message {
  id             String            @id @default(cuid())
  roomId         String
  room           Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  authorId       String
  author         User              @relation("SentMessages", fields: [authorId], references: [id], onDelete: Cascade)
  body           String            @db.Text
  threadParentId String?
  threadParent   Message?          @relation("MessageThread", fields: [threadParentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  threadReplies  Message[]         @relation("MessageThread")
  reactions      MessageReaction[]
  isAi           Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  hiddenAt       DateTime?
  hiddenById     String?
  hiddenReason   ContentHideReason?

  @@index([roomId, createdAt])
  @@index([threadParentId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("MessageReactions", fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
}

model FeedPost {
  id           String   @id @default(cuid())
  authorId     String
  author       User     @relation("AuthoredFeedPosts", fields: [authorId], references: [id], onDelete: Cascade)
  body         String
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  hiddenAt     DateTime?
  hiddenById   String?
  hiddenReason ContentHideReason?

  @@index([createdAt])
}

// Likes on any feed item (FeedPost, BlogPost, Milestone, Project, Idea,
// ActivityEvent, Message, KanbanCardComment, IdeaComment). Not a
// Prisma relation to the target — targetType/targetId is looked up by the
// app layer, matching how the feed already treats these as a loose union.
model FeedLike {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("FeedLikes", fields: [userId], references: [id], onDelete: Cascade)
  targetType String
  targetId   String
  createdAt  DateTime @default(now())

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}

// Comments on any feed item — same loose targetType/targetId pairing as FeedLike.
model FeedComment {
  id           String   @id @default(cuid())
  authorId     String
  author       User     @relation("AuthoredFeedComments", fields: [authorId], references: [id], onDelete: Cascade)
  targetType   String
  targetId     String
  body         String
  createdAt    DateTime @default(now())
  hiddenAt     DateTime?
  hiddenById   String?
  hiddenReason ContentHideReason?

  @@index([targetType, targetId])
}
