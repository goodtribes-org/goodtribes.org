generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SiteRole {
  USER
  ADMIN
  OWNER
}

enum ProjectRole {
  FOUNDER
  ADMIN
  MEMBER
  FOLLOWER
}

enum ProjectPhase {
  IDEA
  PROJECT
  PILOT
  PRODUCTION
  ESTABLISH
  SCALE
  IMPACT
}

// PRD 4c — replaces the dead Project.commercial Boolean (added
// 20260715220000_project_commercial, never actually written anywhere).
enum LegalType {
  COMMERCIAL_UMBRELLA
  COMMERCIAL_AB
  NONPROFIT_UMBRELLA
  NONPROFIT_OWN_ASSOC
}

enum OrganisationRole {
  OWNER
  ADMIN
  MEMBER
}

enum FlagReason {
  SPAM
  HARASSMENT
  OFFENSIVE
  OFF_TOPIC
  FRAUD
  ETHICS_VIOLATION
  OTHER
}

enum FlagStatus {
  PENDING
  ACTIONED
  DISMISSED
}

enum ContentHideReason {
  AUTO_FLAG_THRESHOLD
  ADMIN_ACTION
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  country       String?
  bio           String?
  socialLinks   Json?     @default("{}")
  interests     Int[]     @default([])
  availability  String?
  showProfile   Boolean   @default(false)
  digestOptIn   Boolean   @default(true)
  siteRole      SiteRole  @default(USER)
  suspendedAt   DateTime?
  accounts      Account[]
  sessions      Session[]

  ownedOrganisations      Organisation[]            @relation("OwnedOrganisations")
  organisationMemberships OrganisationMember[]      @relation("OrganisationMemberships")
  joinRequests            OrganisationJoinRequest[] @relation("JoinRequests")
  skills                  UserSkill[]
  createdTasks            WorkspaceTask[]           @relation("CreatedTasks")
  files                   File[]                    @relation("OwnedFiles")
  createdKanbanCards      KanbanCard[]              @relation("CreatedKanbanCards")
  createdTodoLists        TodoList[]                @relation("CreatedTodoLists")
  createdTodoItems        TodoItem[]                @relation("CreatedTodoItems")
  ownedProjects           Project[]                 @relation("OwnedProjects")
  projectMemberships      ProjectMember[]           @relation("ProjectMemberships")
  projectJoinRequests     ProjectJoinRequest[]      @relation("ProjectJoinRequests")
  authoredIdeas           Idea[]                    @relation("AuthoredIdeas")
  ideaVotes               IdeaVote[]                @relation("IdeaVotes")
  ideaEndorsements        IdeaEndorsement[]         @relation("IdeaEndorsements")
  ideaFollowers           IdeaFollower[]            @relation("IdeaFollowers")
  authoredIdeaComments    IdeaComment[]             @relation("AuthoredIdeaComments")
  authoredBlogPosts       BlogPost[]                @relation("AuthoredBlogPosts")
  notifications           Notification[]            @relation("UserNotifications")
  assignedKanbanCards     KanbanCard[]              @relation("AssignedKanbanCards")
  createdMilestones       Milestone[]               @relation("MilestoneCreatedBy")
  activityEvents          ActivityEvent[]           @relation("ActivityEvents")
  createdProjectInvites   ProjectInvite[]           @relation("CreatedProjectInvites")
  createdWikiPages        WikiPage[]                @relation("WikiPageCreatedBy")
  updatedWikiPages        WikiPage[]                @relation("WikiPageUpdatedBy")
  createdOrgInvites       OrgInvite[]               @relation("CreatedOrgInvites")
  fundingPledges          FundingPledge[]           @relation("FundingPledges")
  calendarEvents          CalendarEvent[]           @relation("CreatedCalendarEvents")
  completedSubtasks       KanbanCardSubtask[]       @relation("CompletedSubtasks")
  tokenLedger             TokenLedger[]             @relation("TokenLedger")
  aiTaskReviews           AiTaskReview[]            @relation("AiTaskReviews")
  createdPolls            Poll[]                    @relation("CreatedPolls")
  pollVotes               PollVote[]                @relation("UserPollVotes")
  impactUpdates           ImpactUpdate[]            @relation("ImpactUpdates")
  approvedInstances       ProjectInstance[]         @relation("ApprovedInstances")
  alumni                  ProjectAlumni[]           @relation("AlumniUsers")
  mentorProfile           Mentor?                   @relation("MentorProfile")
  authoredGuides          AcademyGuide[]            @relation("GuideAuthor")
  reviewedGuides          AcademyGuide[]            @relation("GuideReviewer")
  guideCompletions        UserGuideCompletion[]     @relation("GuideCompletions")
  kudosSent               Kudos[]                   @relation("KudosSent")
  kudosReceived           Kudos[]                   @relation("KudosReceived")
  streaks                 UserStreak[]              @relation("UserStreaks")
  dreamPosts              DreamWallPost[]           @relation("DreamPosts")
  dreamReactions          DreamWallReaction[]       @relation("DreamReactions")
  projectFlags            ProjectFlag[]             @relation("FlaggedBy")
  flagReviews             ProjectFlag[]             @relation("FlagReviewer")
  ethicsReviews           EthicsReview[]            @relation("EthicsReviewer")
  kanbanComments          KanbanCardComment[]       @relation("KanbanComments")
  onboardingDone          Boolean                   @default(false)
  tourDismissedAt         DateTime?
  feedPosts               FeedPost[]                @relation("AuthoredFeedPosts")
  feedLikes               FeedLike[]                @relation("FeedLikes")
  feedComments            FeedComment[]             @relation("AuthoredFeedComments")
  roomParticipations      RoomParticipant[]         @relation("RoomParticipant")
  sentMessages            Message[]                 @relation("SentMessages")
  messageReactions        MessageReaction[]         @relation("MessageReactions")
  orgFlagsRaised          OrganisationFlag[]         @relation("OrgFlaggedBy")
  orgFlagReviews          OrganisationFlag[]         @relation("OrgFlagReviewer")
  orgEthicsReviews        OrganisationEthicsReview[] @relation("OrgEthicsReviewer")
  orgReviewsAuthored      OrganisationReview[]       @relation("OrgReviewAuthor")
  leanCanvasEdits         LeanCanvas[]               @relation("LeanCanvasUpdatedBy")
  leanCanvasComments      LeanCanvasComment[]        @relation("LeanCanvasCommentAuthor")
  contentFlagsRaised     ContentFlag[]               @relation("ContentFlaggedBy")
  contentFlagReviews     ContentFlag[]               @relation("ContentFlagReviewer")
  priorityChanges        KanbanCardPriorityChange[]  @relation("PriorityChanges")
  gtLedger               GtLedger[]                  @relation("GtLedger")
  phaseTransitions       PhaseTransition[]           @relation("PhaseTransitions")
  completedChecklistItems InitiativeChecklistItem[]  @relation("CompletedChecklistItems")
  createdPlatformPolls   PlatformPoll[]              @relation("CreatedPlatformPolls")
  platformPollCandidacies PlatformPollOption[]       @relation("PlatformPollCandidacies")
  platformPollVotes      PlatformPollVote[]          @relation("PlatformPollVotes")
  reviewCouncilMemberships ReviewCouncilMember[]      @relation("ReviewCouncilMemberships")
  exclusionCasesReported  ExclusionCase[]             @relation("ReportedInExclusionCases")
  exclusionCasesFiled     ExclusionCase[]             @relation("FiledExclusionCases")
  exclusionCaseVotes      ExclusionCaseVote[]         @relation("ExclusionCaseVotes")
  requestedLegalTypeChanges LegalTypeChangeRequest[]  @relation("RequestedLegalTypeChanges")
  executedLegalTypeChanges  LegalTypeChangeRequest[]  @relation("ExecutedLegalTypeChanges")
  proposedProfitDistributions ProfitDistributionProposal[] @relation("ProposedProfitDistributions")
  executedProfitDistributions ProfitDistributionProposal[] @relation("ExecutedProfitDistributions")
  personalProfitAllocations    PersonalProfitAllocation[]
  recordedImpactFundEntries    ImpactFundLedger[]         @relation("RecordedImpactFundEntries")
  openedImpactFundRounds       ImpactFundAllocationRound[] @relation("OpenedImpactFundRounds")
  initiatedPartnerships        Partnership[]               @relation("PartnershipInitiatedBy")
  respondedPartnerships        Partnership[]               @relation("PartnershipRespondedBy")
}

model Skill {
  id          String         @id @default(cuid())
  name        String         @unique
  tag         String
  description String
  slug        String         @unique
  createdAt   DateTime       @default(now())
  users       UserSkill[]
  projects    ProjectSkill[]
  organisations OrganisationSkill[]
}

model UserSkill {
  id      String   @id @default(cuid())
  userId  String
  skillId String
  addedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
}

model Organisation {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  category    String?
  country     String?  // free text, normalized via lib/geo.ts — real geography signal for partnership matchmaking
  imageUrl    String?
  isPublic    Boolean  @default(true)
  verified    Boolean  @default(false)
  tourDismissedAt DateTime?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner          User                      @relation("OwnedOrganisations", fields: [ownerId], references: [id], onDelete: Cascade)
  members        OrganisationMember[]
  joinRequests   OrganisationJoinRequest[]
  rooms          Room[]                    @relation("OrgRooms")
  workspaceTasks WorkspaceTask[]           @relation("OrgTasks")
  projects       Project[]
  invites        OrgInvite[]
  neededSkills   OrganisationSkill[]
  flags          OrganisationFlag[]        @relation("OrganisationFlags")
  ethicsReviews  OrganisationEthicsReview[] @relation("OrganisationEthicsReviews")
  reviews        OrganisationReview[]      @relation("OrganisationReviews")
  files          File[]                    @relation("OrganisationFiles")
  activityEvents ActivityEvent[]
  partnerships   Partnership[]             @relation("OrganisationPartnerships")
}

model OrganisationFlag {
  id             String                    @id @default(cuid())
  organisationId String
  organisation   Organisation              @relation("OrganisationFlags", fields: [organisationId], references: [id], onDelete: Cascade)
  flaggedById    String
  flaggedBy      User                      @relation("OrgFlaggedBy", fields: [flaggedById], references: [id])
  reason         String
  status         String                    @default("pending")
  reviewedById   String?
  reviewedBy     User?                     @relation("OrgFlagReviewer", fields: [reviewedById], references: [id])
  decisionNote   String?
  ethicsReview   OrganisationEthicsReview?
  createdAt      DateTime                  @default(now())

  @@index([organisationId])
}

model OrganisationEthicsReview {
  id                 String            @id @default(cuid())
  organisationId     String
  organisation       Organisation      @relation("OrganisationEthicsReviews", fields: [organisationId], references: [id], onDelete: Cascade)
  reviewerId         String
  reviewer           User              @relation("OrgEthicsReviewer", fields: [reviewerId], references: [id])
  organisationFlagId String?           @unique
  organisationFlag   OrganisationFlag? @relation(fields: [organisationFlagId], references: [id])
  contentFlagId      String?           @unique
  contentFlag        ContentFlag?      @relation("OrgContentFlagEthicsReview", fields: [contentFlagId], references: [id])
  outcome            String
  note               String?
  createdAt          DateTime          @default(now())

  @@index([organisationId])
}

model OrganisationReview {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation("OrganisationReviews", fields: [organisationId], references: [id], onDelete: Cascade)
  authorId       String
  author         User         @relation("OrgReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  rating         Int
  comment        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organisationId, authorId])
  @@index([organisationId])
}

model OrganisationSkill {
  id             String   @id @default(cuid())
  organisationId String
  skillId        String
  addedAt        DateTime @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  skill        Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([organisationId, skillId])
}

model OrganisationMember {
  id             String   @id @default(cuid())
  organisationId String
  userId         String
  role           OrganisationRole @default(MEMBER)
  joinedAt       DateTime @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user         User         @relation("OrganisationMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organisationId, userId])
}

model OrganisationJoinRequest {
  id             String   @id @default(cuid())
  organisationId String
  userId         String
  status         String   @default("pending")
  createdAt      DateTime @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user         User         @relation("JoinRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organisationId, userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model WorkspaceTask {
  id             String   @id @default(cuid())
  organisationId String
  title          String
  description    String?
  done           Boolean  @default(false)
  createdAt      DateTime @default(now())
  createdById    String

  organisation Organisation @relation("OrgTasks", fields: [organisationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Cascade)
}

model File {
  id             String        @id @default(cuid())
  key            String        @unique
  bucket         String
  name           String
  size           Int
  mimeType       String
  ownerId        String
  owner          User          @relation("OwnedFiles", fields: [ownerId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?      @relation("ProjectFiles", fields: [projectId], references: [id], onDelete: Cascade)
  organisationId String?
  organisation   Organisation? @relation("OrganisationFiles", fields: [organisationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())

  @@index([projectId])
  @@index([organisationId])
}

model KanbanCard {
  id          String    @id @default(cuid())
  projectSlug String
  title       String
  description String?
  dueDate     DateTime?
  startDate   DateTime?
  priority    String    @default("normal")
  priorityLockedAt DateTime?
  lockedTokenValue Float?
  category    String?
  assigneeId  String?
  openToPublic Boolean  @default(false)
  claimedAt   DateTime?
  column      String    @default("BACKLOG")
  order       Int       @default(0)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy       User                       @relation("CreatedKanbanCards", fields: [createdById], references: [id], onDelete: Cascade)
  assignee        User?                      @relation("AssignedKanbanCards", fields: [assigneeId], references: [id], onDelete: SetNull)
  project         Project                    @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  estimate        TaskEstimate?
  tokenLedger     TokenLedger[]              @relation("KanbanTokens")
  aiTaskRuns      AiTaskRun[]                @relation("KanbanAiRuns")
  subtasks        KanbanCardSubtask[]
  comments        KanbanCardComment[]
  priorityChanges KanbanCardPriorityChange[]

  @@index([projectSlug, column])
  @@index([openToPublic, assigneeId])
}

model KanbanCardSubtask {
  id            String     @id @default(cuid())
  cardId        String
  card          KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  title         String
  done          Boolean    @default(false)
  order         Int        @default(0)
  createdAt     DateTime   @default(now())
  completedById String?
  completedBy   User?      @relation("CompletedSubtasks", fields: [completedById], references: [id], onDelete: SetNull)
  completedAt   DateTime?

  @@index([cardId])
}

model KanbanCardComment {
  id           String     @id @default(cuid())
  cardId       String
  card         KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  authorId     String
  author       User       @relation("KanbanComments", fields: [authorId], references: [id], onDelete: Cascade)
  body         String     @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  hiddenAt     DateTime?
  hiddenById   String?
  hiddenReason ContentHideReason?

  @@index([cardId])
}

model TodoList {
  id          String   @id @default(cuid())
  projectSlug String
  name        String
  order       Int      @default(0)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User       @relation("CreatedTodoLists", fields: [createdById], references: [id], onDelete: Cascade)
  project   Project    @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  items     TodoItem[]

  @@index([projectSlug])
}

model TodoItem {
  id          String    @id @default(cuid())
  listId      String
  projectSlug String
  title       String
  done        Boolean   @default(false)
  dueDate     DateTime?
  order       Int       @default(0)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User     @relation("CreatedTodoItems", fields: [createdById], references: [id], onDelete: Cascade)
  list      TodoList @relation(fields: [listId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)

  @@index([listId])
  @@index([projectSlug])
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  summary     String?
  description String?
  phase       ProjectPhase @default(IDEA)
  checklistDismissedAt DateTime?
  archivedAt  DateTime?
  visibility  String   @default("public")
  category    String?
  tags        String[]
  imageUrl    String?
  links       String[] @default([])
  sdgGoals    Int[]
  legalType   LegalType @default(NONPROFIT_UMBRELLA)
  commercialUmbrellaEntityId String?
  commercialUmbrellaEntity   CommercialUmbrellaEntity? @relation(fields: [commercialUmbrellaEntityId], references: [id], onDelete: SetNull)
  ownerId     String
  orgId       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner              User                 @relation("OwnedProjects", fields: [ownerId], references: [id], onDelete: Cascade)
  org                Organisation?        @relation(fields: [orgId], references: [id])
  members            ProjectMember[]
  joinRequests       ProjectJoinRequest[]
  kanbanCards        KanbanCard[]
  todoLists          TodoList[]
  todoItems          TodoItem[]
  blogPosts          BlogPost[]
  milestones         Milestone[]
  activityEvents     ActivityEvent[]
  invites            ProjectInvite[]
  wikiPages          WikiPage[]
  neededSkills       ProjectSkill[]
  files              File[]               @relation("ProjectFiles")
  fundingCampaign    FundingCampaign?
  rooms              Room[]               @relation("ProjectRooms")
  calendarEvents     CalendarEvent[]      @relation("ProjectCalendarEvents")
  tokenLedger        TokenLedger[]        @relation("ProjectTokenLedger")
  polls              Poll[]               @relation("ProjectPolls")
  impactMetrics      ImpactMetric[]       @relation("ProjectImpactMetrics")
  maturity           ProjectMaturity?     @relation("ProjectMaturity")
  leanCanvas         LeanCanvas?          @relation("ProjectLeanCanvas")
  leanCanvasComments LeanCanvasComment[]  @relation("ProjectLeanCanvasComments")
  parentInstances    ProjectInstance[]    @relation("ParentInstances")
  childInstance      ProjectInstance?     @relation("ChildInstance")
  alumni             ProjectAlumni[]      @relation("ProjectAlumni")
  openForReplication Boolean              @default(false)
  mentorships        MentorshipRequest[]  @relation("ProjectMentorships")
  kudos              Kudos[]              @relation("ProjectKudos")
  streaks            UserStreak[]         @relation("ProjectStreaks")
  flags              ProjectFlag[]        @relation("ProjectFlags")
  exclusionCases     ExclusionCase[]
  legalTypeChangeRequests LegalTypeChangeRequest[]
  ethicsReviews      EthicsReview[]       @relation("EthicsReviews")
  phaseTransitions   PhaseTransition[]
  checklistItems     InitiativeChecklistItem[]
  convertedFromRoom  Room?                @relation("RoomConvertedToProject")
  profitDistributionProposals ProfitDistributionProposal[]
  profitDistributions         ProfitDistribution[]
  impactFundPayouts           ImpactFundLedger[]          @relation("ImpactFundPayouts")
  impactFundPollOptions       PlatformPollOption[]        @relation("ImpactFundPollOptionProjects")
  partnerships                Partnership[]               @relation("ProjectPartnerships")
}

model ProjectSkill {
  id        String   @id @default(cuid())
  projectId String
  skillId   String
  addedAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([projectId, skillId])
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(MEMBER)
  joinedAt  DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("ProjectMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model PhaseTransition {
  id          String        @id @default(cuid())
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromPhase   ProjectPhase?
  toPhase     ProjectPhase
  changedById String
  changedBy   User          @relation("PhaseTransitions", fields: [changedById], references: [id])
  changedAt   DateTime      @default(now())

  @@index([projectId])
}

model InitiativeChecklistItem {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase         ProjectPhase
  itemKey       String
  completedAt   DateTime?
  completedById String?
  completedBy   User?        @relation("CompletedChecklistItems", fields: [completedById], references: [id], onDelete: SetNull)

  @@unique([projectId, itemKey])
  @@index([projectId])
}

model Idea {
  id             String   @id @default(cuid())
  title          String
  description    String?
  problem        String?
  solution       String?
  sdgGoals       Int[]
  category       String?
  tags           String[]
  imageUrl       String?
  targetRegion   String   @default("global")
  estimatedReach Int?
  status         String   @default("open")
  viewCount      Int      @default(0)
  authorId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  hiddenAt       DateTime?
  hiddenById     String?
  hiddenReason   ContentHideReason?

  author           User              @relation("AuthoredIdeas", fields: [authorId], references: [id], onDelete: Cascade)
  votes            IdeaVote[]
  endorsements     IdeaEndorsement[]
  followers        IdeaFollower[]
  comments         IdeaComment[]
  convertedFromRoom Room?            @relation("RoomConvertedToIdea")
}

model IdeaVote {
  id     String @id @default(cuid())
  ideaId String
  userId String

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User @relation("IdeaVotes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ideaId, userId])
}

model IdeaEndorsement {
  id        String   @id @default(cuid())
  ideaId    String
  userId    String
  createdAt DateTime @default(now())

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User @relation("IdeaEndorsements", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ideaId, userId])
}

model IdeaFollower {
  id        String   @id @default(cuid())
  ideaId    String
  userId    String
  createdAt DateTime @default(now())

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User @relation("IdeaFollowers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ideaId, userId])
}

model ProjectJoinRequest {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  message   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("ProjectJoinRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model BlogPost {
  id          String   @id @default(cuid())
  projectSlug String
  authorId    String
  title       String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  author  User    @relation("AuthoredBlogPosts", fields: [authorId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  url       String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model IdeaComment {
  id           String   @id @default(cuid())
  ideaId       String
  authorId     String
  content      String
  createdAt    DateTime @default(now())
  hiddenAt     DateTime?
  hiddenById   String?
  hiddenReason ContentHideReason?

  idea   Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  author User @relation("AuthoredIdeaComments", fields: [authorId], references: [id], onDelete: Cascade)
}

model Milestone {
