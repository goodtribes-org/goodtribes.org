generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  country       String?
  bio           String?
  socialLinks   Json?     @default("{}")
  interests    Int[]    @default([])
  availability String?
  showProfile   Boolean   @default(false)
  digestOptIn   Boolean   @default(true)
  accounts      Account[]
  sessions      Session[]

  ownedOrganisations      Organisation[]            @relation("OwnedOrganisations")
  organisationMemberships OrganisationMember[]      @relation("OrganisationMemberships")
  joinRequests            OrganisationJoinRequest[] @relation("JoinRequests")
  skills                  UserSkill[]
  authoredMessages        WorkspaceMessage[]        @relation("AuthoredMessages")
  createdTasks            WorkspaceTask[]            @relation("CreatedTasks")
  files                   File[]                    @relation("OwnedFiles")
  createdKanbanCards      KanbanCard[]              @relation("CreatedKanbanCards")
  createdTodoLists        TodoList[]                @relation("CreatedTodoLists")
  createdTodoItems        TodoItem[]                @relation("CreatedTodoItems")
  ownedProjects           Project[]                 @relation("OwnedProjects")
  projectMemberships      ProjectMember[]           @relation("ProjectMemberships")
  projectJoinRequests     ProjectJoinRequest[]      @relation("ProjectJoinRequests")
  authoredIdeas           Idea[]                    @relation("AuthoredIdeas")
  ideaVotes               IdeaVote[]                @relation("IdeaVotes")
  ideaEndorsements        IdeaEndorsement[]         @relation("IdeaEndorsements")
  ideaFollowers           IdeaFollower[]            @relation("IdeaFollowers")
  authoredIdeaComments    IdeaComment[]             @relation("AuthoredIdeaComments")
  authoredBlogPosts       BlogPost[]                @relation("AuthoredBlogPosts")
  notifications           Notification[]            @relation("UserNotifications")
  assignedKanbanCards     KanbanCard[]              @relation("AssignedKanbanCards")
  createdMilestones       Milestone[]               @relation("MilestoneCreatedBy")
  activityEvents          ActivityEvent[]           @relation("ActivityEvents")
  createdProjectInvites   ProjectInvite[]           @relation("CreatedProjectInvites")
  createdWikiPages        WikiPage[]                @relation("WikiPageCreatedBy")
  updatedWikiPages        WikiPage[]                @relation("WikiPageUpdatedBy")
  createdOrgInvites       OrgInvite[]               @relation("CreatedOrgInvites")
  fundingPledges          FundingPledge[]           @relation("FundingPledges")
  calendarEvents   CalendarEvent[] @relation("CreatedCalendarEvents")
  timeLogs         TimeLog[]       @relation("UserTimeLogs")
  timeLogReviews   TimeLog[]       @relation("ReviewedTimeLogs")
  tokenLedger      TokenLedger[]   @relation("TokenLedger")
  aiTaskReviews    AiTaskReview[]  @relation("AiTaskReviews")
  createdPolls     Poll[]          @relation("CreatedPolls")
  pollVotes        PollVote[]      @relation("UserPollVotes")
  impactUpdates    ImpactUpdate[]    @relation("ImpactUpdates")
  approvedInstances ProjectInstance[] @relation("ApprovedInstances")
  alumni           ProjectAlumni[]   @relation("AlumniUsers")
  mentorProfile    Mentor?               @relation("MentorProfile")
  authoredGuides   AcademyGuide[]        @relation("GuideAuthor")
  reviewedGuides   AcademyGuide[]        @relation("GuideReviewer")
  guideCompletions UserGuideCompletion[] @relation("GuideCompletions")
  kudosSent        Kudos[]               @relation("KudosSent")
  kudosReceived    Kudos[]               @relation("KudosReceived")
  streaks          UserStreak[]          @relation("UserStreaks")
  dreamPosts       DreamWallPost[]       @relation("DreamPosts")
  dreamReactions   DreamWallReaction[]   @relation("DreamReactions")
  projectFlags     ProjectFlag[]         @relation("FlaggedBy")
  flagReviews      ProjectFlag[]         @relation("FlagReviewer")
  ethicsReviews      EthicsReview[]        @relation("EthicsReviewer")
  channelMessages    ChannelMessage[]         @relation("ChannelMessages")
  channelReactions   ChannelMessageReaction[] @relation("ChannelReactions")
  channelReadMarkers ChannelReadMarker[]      @relation("ChannelReadMarkers")
  kanbanComments     KanbanCardComment[]     @relation("KanbanComments")
  onboardingDone       Boolean               @default(false)
}

model Skill {
  id          String         @id @default(cuid())
  name        String         @unique
  tag         String
  description String
  slug        String         @unique
  createdAt   DateTime       @default(now())
  users       UserSkill[]
  projects    ProjectSkill[]
}

model UserSkill {
  id      String   @id @default(cuid())
  userId  String
  skillId String
  addedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
}

model Organisation {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?
  isPublic    Boolean  @default(true)
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner             User                      @relation("OwnedOrganisations", fields: [ownerId], references: [id], onDelete: Cascade)
  members           OrganisationMember[]
  joinRequests      OrganisationJoinRequest[]
  workspaceMessages WorkspaceMessage[]        @relation("OrgMessages")
  workspaceTasks    WorkspaceTask[]            @relation("OrgTasks")
  projects          Project[]
  invites           OrgInvite[]
}

model OrganisationMember {
  id             String   @id @default(cuid())
  organisationId String
  userId         String
  role           String   @default("member")
  joinedAt       DateTime @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user         User         @relation("OrganisationMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organisationId, userId])
}

model OrganisationJoinRequest {
  id             String   @id @default(cuid())
  organisationId String
  userId         String
  status         String   @default("pending")
  createdAt      DateTime @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user         User         @relation("JoinRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organisationId, userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model WorkspaceMessage {
  id             String   @id @default(cuid())
  organisationId String
  authorId       String
  content        String
  createdAt      DateTime @default(now())

  organisation Organisation @relation("OrgMessages", fields: [organisationId], references: [id], onDelete: Cascade)
  author       User         @relation("AuthoredMessages", fields: [authorId], references: [id], onDelete: Cascade)
}

model WorkspaceTask {
  id             String   @id @default(cuid())
  organisationId String
  title          String
  description    String?
  done           Boolean  @default(false)
  createdAt      DateTime @default(now())
  createdById    String

  organisation Organisation @relation("OrgTasks", fields: [organisationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Cascade)
}

model File {
  id        String   @id @default(cuid())
  key       String   @unique
  bucket    String
  name      String
  size      Int
  mimeType  String
  ownerId   String
  owner     User     @relation("OwnedFiles", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model KanbanCard {
  id          String   @id @default(cuid())
  projectSlug String
  title       String
  description String?
  dueDate     DateTime?
  startDate   DateTime?
  priority    String    @default("normal")
  assigneeId  String?
  column      String    @default("BACKLOG")
  order       Int       @default(0)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User    @relation("CreatedKanbanCards", fields: [createdById], references: [id], onDelete: Cascade)
  assignee  User?   @relation("AssignedKanbanCards", fields: [assigneeId], references: [id], onDelete: SetNull)
  project   Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  estimate         TaskEstimate?
  timeLogs         TimeLog[]       @relation("KanbanTimeLogs")
  tokenLedger      TokenLedger[]   @relation("KanbanTokens")
  aiTaskRuns       AiTaskRun[]     @relation("KanbanAiRuns")
  subtasks         KanbanCardSubtask[]
  comments         KanbanCardComment[]

  @@index([projectSlug, column])
}

model KanbanCardSubtask {
  id        String     @id @default(cuid())
  cardId    String
  card      KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  title     String
  done      Boolean    @default(false)
  order     Int        @default(0)
  createdAt DateTime   @default(now())

  @@index([cardId])
}

model KanbanCardComment {
  id        String     @id @default(cuid())
  cardId    String
  card      KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  authorId  String
  author    User       @relation("KanbanComments", fields: [authorId], references: [id], onDelete: Cascade)
  body      String     @db.Text
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([cardId])
}

model TodoList {
  id          String     @id @default(cuid())
  projectSlug String
  name        String
  order       Int        @default(0)
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  createdBy User       @relation("CreatedTodoLists", fields: [createdById], references: [id], onDelete: Cascade)
  project   Project    @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  items     TodoItem[]

  @@index([projectSlug])
}

model TodoItem {
  id          String    @id @default(cuid())
  listId      String
  projectSlug String
  title       String
  done        Boolean   @default(false)
  dueDate     DateTime?
  order       Int       @default(0)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User     @relation("CreatedTodoItems", fields: [createdById], references: [id], onDelete: Cascade)
  list      TodoList @relation(fields: [listId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)

  @@index([listId])
  @@index([projectSlug])
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  status      String   @default("concept")
  visibility  String   @default("public")
  category    String?
  tags        String[]
  imageUrl    String?
  links       String[] @default([])
  sdgGoals    Int[]
  ownerId     String
  orgId       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner          User                 @relation("OwnedProjects", fields: [ownerId], references: [id], onDelete: Cascade)
  org            Organisation?        @relation(fields: [orgId], references: [id])
  members        ProjectMember[]
  joinRequests   ProjectJoinRequest[]
  kanbanCards    KanbanCard[]
  todoLists      TodoList[]
  todoItems      TodoItem[]
  blogPosts      BlogPost[]
  milestones     Milestone[]
  activityEvents ActivityEvent[]
  invites        ProjectInvite[]
  wikiPages      WikiPage[]
  neededSkills     ProjectSkill[]
  fundingCampaign  FundingCampaign?
  channels         Channel[]       @relation("ProjectChannels")
  calendarEvents   CalendarEvent[] @relation("ProjectCalendarEvents")
  tokenLedger      TokenLedger[]   @relation("ProjectTokenLedger")
  polls            Poll[]          @relation("ProjectPolls")
  impactMetrics    ImpactMetric[]    @relation("ProjectImpactMetrics")
  maturity         ProjectMaturity?  @relation("ProjectMaturity")
  parentInstances  ProjectInstance[] @relation("ParentInstances")
  childInstance    ProjectInstance?  @relation("ChildInstance")
  alumni           ProjectAlumni[]   @relation("ProjectAlumni")
  openForReplication Boolean         @default(false)
  mentorships   MentorshipRequest[] @relation("ProjectMentorships")
  kudos         Kudos[]             @relation("ProjectKudos")
  streaks       UserStreak[]        @relation("ProjectStreaks")
  flags         ProjectFlag[]       @relation("ProjectFlags")
  ethicsReviews EthicsReview[]      @relation("EthicsReviews")
}

model ProjectSkill {
  id        String   @id @default(cuid())
  projectId String
  skillId   String
  addedAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([projectId, skillId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("collaborator")
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("ProjectMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Idea {
  id              String   @id @default(cuid())
  title           String
  description     String?
  problem         String?
  solution        String?
  sdgGoals        Int[]
  category        String?
  tags            String[]
  imageUrl        String?
  targetRegion    String   @default("global")
  estimatedReach  Int?
  status          String   @default("open")
  viewCount       Int      @default(0)
  authorId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author       User              @relation("AuthoredIdeas", fields: [authorId], references: [id], onDelete: Cascade)
  votes        IdeaVote[]
  endorsements IdeaEndorsement[]
  followers    IdeaFollower[]
  comments     IdeaComment[]
}

model IdeaVote {
  id     String @id @default(cuid())
  ideaId String
  userId String

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User @relation("IdeaVotes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ideaId, userId])
}

model IdeaEndorsement {
  id        String   @id @default(cuid())
  ideaId    String
  userId    String
  createdAt DateTime @default(now())

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User @relation("IdeaEndorsements", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ideaId, userId])
}

model IdeaFollower {
  id        String   @id @default(cuid())
  ideaId    String
  userId    String
  createdAt DateTime @default(now())

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User @relation("IdeaFollowers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ideaId, userId])
}

model ProjectJoinRequest {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  message   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("ProjectJoinRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model BlogPost {
  id          String   @id @default(cuid())
  projectSlug String
  authorId    String
  title       String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  author  User    @relation("AuthoredBlogPosts", fields: [authorId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  url       String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model IdeaComment {
  id        String   @id @default(cuid())
  ideaId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  idea   Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  author User @relation("AuthoredIdeaComments", fields: [authorId], references: [id], onDelete: Cascade)
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  dueDate     DateTime?
  status      String    @default("pending")
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("MilestoneCreatedBy", fields: [createdById], references: [id])
}

model ProjectInvite {
  id          String    @id @default(cuid())
  projectId   String
  email       String?
  token       String    @unique @default(cuid())
  role        String    @default("collaborator")
  createdById String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("CreatedProjectInvites", fields: [createdById], references: [id])
}

model WikiPage {
  id          String   @id @default(cuid())
  projectSlug String
  slug        String
  title       String
  content     String   @default("")
  order       Int      @default(0)
  createdById String
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  createdBy User    @relation("WikiPageCreatedBy", fields: [createdById], references: [id])
  updatedBy User?   @relation("WikiPageUpdatedBy", fields: [updatedById], references: [id])

  @@unique([projectSlug, slug])
}

model OrgInvite {
  id          String    @id @default(cuid())
  orgId       String
  email       String
  token       String    @unique @default(cuid())
  role        String    @default("member")
  createdById String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  org       Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User         @relation("CreatedOrgInvites", fields: [createdById], references: [id])
}

model ActivityEvent {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("ActivityEvents", fields: [userId], references: [id])
}


model FundingCampaign {
  id          String   @id @default(cuid())
  projectId   String   @unique
  title       String
  description String?
  goal        Int
  currency    String   @default("SEK")
  status          String   @default("active")
  campaignType    String   @default("donation")
  deadline        DateTime?
  platformFee     Float    @default(5)
  stripeAccountId String?
  createdAt       DateTime @default(now())

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pledges     FundingPledge[]
  rewardTiers FundingRewardTier[]
  expenses    FundingExpense[]
}

model FundingPledge {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  amount     Int
  message          String?
  stripeSessionId  String?
  pledgeStatus     String  @default("confirmed")
  rewardTierId     String?
  createdAt        DateTime @default(now())

  campaign    FundingCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user        User               @relation("FundingPledges", fields: [userId], references: [id], onDelete: Cascade)
  rewardTier  FundingRewardTier? @relation(fields: [rewardTierId], references: [id], onDelete: SetNull)

  @@unique([campaignId, userId])
}


model CalendarEvent {
  id          String    @id @default(cuid())
  projectSlug String
  project     Project   @relation("ProjectCalendarEvents", fields: [projectSlug], references: [slug], onDelete: Cascade)
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime?
  type        String    @default("custom")
  createdById String
  createdBy   User      @relation("CreatedCalendarEvents", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  @@index([projectSlug, startsAt])
}

model TaskEstimate {
  id           String     @id @default(cuid())
  kanbanCardId String     @unique
  kanbanCard   KanbanCard @relation(fields: [kanbanCardId], references: [id], onDelete: Cascade)
  aiHours      Float
  aiConfidence String
  aiReasoning  String     @db.Text
  manualHours  Float?
  lockedAt     DateTime?
  createdAt    DateTime   @default(now())
}

model TimeLog {
  id           String     @id @default(cuid())
  kanbanCardId String
  kanbanCard   KanbanCard @relation("KanbanTimeLogs", fields: [kanbanCardId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation("UserTimeLogs", fields: [userId], references: [id])
  loggedHours  Float
  status       String     @default("pending")
  reviewedBy   String?
  reviewer     User?      @relation("ReviewedTimeLogs", fields: [reviewedBy], references: [id])
  reviewedAt   DateTime?
  note         String?
  createdAt    DateTime   @default(now())

  @@index([kanbanCardId])
  @@index([userId])
}

model TokenLedger {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation("TokenLedger", fields: [userId], references: [id])
  projectSlug  String
  project      Project     @relation("ProjectTokenLedger", fields: [projectSlug], references: [slug])
  kanbanCardId String?
  kanbanCard   KanbanCard? @relation("KanbanTokens", fields: [kanbanCardId], references: [id], onDelete: SetNull)
  tokens       Float
  reason       String
  createdAt    DateTime    @default(now())

  @@index([userId])
  @@index([projectSlug])
}

model AiTaskRun {
  id             String         @id @default(cuid())
  kanbanCardId   String
  kanbanCard     KanbanCard     @relation("KanbanAiRuns", fields: [kanbanCardId], references: [id], onDelete: Cascade)
  agentType      String
  status         String         @default("running")
  outputMarkdown String?        @db.Text
  attemptNumber  Int            @default(1)
  feedback       String?        @db.Text
  createdAt      DateTime       @default(now())
  completedAt    DateTime?
  reviews        AiTaskReview[]

  @@index([kanbanCardId])
}

model AiTaskReview {
  id            String     @id @default(cuid())
  aiTaskRunId   String
  aiTaskRun     AiTaskRun  @relation(fields: [aiTaskRunId], references: [id], onDelete: Cascade)
  reviewerId    String
  reviewer      User       @relation("AiTaskReviews", fields: [reviewerId], references: [id])
  decision      String
  feedback      String?    @db.Text
  tokensAwarded Float?
  createdAt     DateTime   @default(now())
}

model Poll {
  id            String       @id @default(cuid())
  projectSlug   String
  project       Project      @relation("ProjectPolls", fields: [projectSlug], references: [slug], onDelete: Cascade)
  createdById   String
  createdBy     User         @relation("CreatedPolls", fields: [createdById], references: [id])
  title         String
  description   String?      @db.Text
  type          String       @default("yes_no")
  status        String       @default("open")
  visibility    String       @default("live")
  isBinding     Boolean      @default(false)
  quorumPercent Float?
  deadline      DateTime?
  closedAt      DateTime?
  createdAt     DateTime     @default(now())
  options       PollOption[]
  votes         PollVote[]

  @@index([projectSlug])
}

model PollOption {
  id          String     @id @default(cuid())
  pollId      String
  poll        Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label       String
  description String?
  sortOrder   Int        @default(0)
  votes       PollVote[]
}

model PollVote {
  id           String     @id @default(cuid())
  pollId       String
  poll         Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollOptionId String
  pollOption   PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation("UserPollVotes", fields: [userId], references: [id])
  tokenWeight  Float
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([pollId, pollOptionId, userId])
  @@index([pollId, userId])
}

model FundingRewardTier {
  id          String          @id @default(cuid())
  campaignId  String
  campaign    FundingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  title       String
  description String?
  minAmount   Int
  maxBackers  Int?
  sortOrder   Int             @default(0)
  pledges     FundingPledge[]
  createdAt   DateTime        @default(now())

  @@index([campaignId])
}

model FundingExpense {
  id          String          @id @default(cuid())
  campaignId  String
  campaign    FundingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  title       String
  amount      Int
  description String?
  receiptUrl  String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())

  @@index([campaignId])
}

model ImpactMetric {
  id           String          @id @default(cuid())
  projectSlug  String
  project      Project         @relation("ProjectImpactMetrics", fields: [projectSlug], references: [slug], onDelete: Cascade)
  label        String
  unit         String
  targetValue  Float?
  currentValue Float           @default(0)
  description  String?
  updates      ImpactUpdate[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([projectSlug])
}

model ImpactUpdate {
  id              String       @id @default(cuid())
  impactMetricId  String
  impactMetric    ImpactMetric @relation(fields: [impactMetricId], references: [id], onDelete: Cascade)
  value           Float
  note            String?
  updatedById     String
  updatedBy       User         @relation("ImpactUpdates", fields: [updatedById], references: [id])
  createdAt       DateTime     @default(now())

  @@index([impactMetricId])
}

model ProjectMaturity {
  id               String   @id @default(cuid())
  projectSlug      String   @unique
  project          Project  @relation("ProjectMaturity", fields: [projectSlug], references: [slug], onDelete: Cascade)
  score            Int      @default(0)
  scoreBreakdown   Json?
  scaleInitiatedAt DateTime?
  scalingPlan      String?  @db.Text
  finalReport      String?  @db.Text
  calculatedAt     DateTime @default(now())
}

model ProjectInstance {
  id              String   @id @default(cuid())
  parentSlug      String
  parent          Project  @relation("ParentInstances", fields: [parentSlug], references: [slug], onDelete: Cascade)
  childSlug       String   @unique
  child           Project  @relation("ChildInstance", fields: [childSlug], references: [slug], onDelete: Cascade)
  region          String
  status          String   @default("pending")
  approvedById    String?
  approvedBy      User?    @relation("ApprovedInstances", fields: [approvedById], references: [id])
  createdAt       DateTime @default(now())

  @@unique([parentSlug, childSlug])
}

model ProjectAlumni {
  id             String   @id @default(cuid())
  projectSlug    String
  project        Project  @relation("ProjectAlumni", fields: [projectSlug], references: [slug], onDelete: Cascade)
  userId         String
  user           User     @relation("AlumniUsers", fields: [userId], references: [id])
  tokensEarned   Float    @default(0)
  badgeIssuedAt  DateTime @default(now())
  finalReport    String?  @db.Text

  @@unique([projectSlug, userId])
  @@index([projectSlug])
}

model Mentor {
  id          String               @id @default(cuid())
  userId      String               @unique
  user        User                 @relation("MentorProfile", fields: [userId], references: [id], onDelete: Cascade)
  categories  String[]
  bio         String?
  verified    Boolean              @default(false)
  requests    MentorshipRequest[]
  createdAt   DateTime             @default(now())
}

model MentorshipRequest {
  id          String              @id @default(cuid())
  projectId   String
  project     Project             @relation("ProjectMentorships", fields: [projectId], references: [id], onDelete: Cascade)
  mentorId    String
  mentor      Mentor              @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  status      String              @default("pending")
  message     String?
  sessionAt   DateTime?
  tokensAwarded Float?
  feedback    MentorshipFeedback?
  createdAt   DateTime            @default(now())

  @@index([projectId])
  @@index([mentorId])
}

model MentorshipFeedback {
  id                  String            @id @default(cuid())
  mentorshipRequestId String            @unique
  mentorshipRequest   MentorshipRequest @relation(fields: [mentorshipRequestId], references: [id], onDelete: Cascade)
  rating              Int
  comment             String?
  createdAt           DateTime          @default(now())
}

model AcademyGuide {
  id               String                @id @default(cuid())
  title            String
  bodyMarkdown     String                @db.Text
  category         String
  authorId         String
  author           User                  @relation("GuideAuthor", fields: [authorId], references: [id])
  reviewedById     String?
  reviewedBy       User?                 @relation("GuideReviewer", fields: [reviewedById], references: [id])
  difficulty       String                @default("beginner")
  readTimeMinutes  Int                   @default(5)
  published        Boolean               @default(false)
  completions      UserGuideCompletion[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([category])
}

model UserGuideCompletion {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation("GuideCompletions", fields: [userId], references: [id], onDelete: Cascade)
  guideId     String
  guide       AcademyGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)
  completedAt DateTime     @default(now())

  @@unique([userId, guideId])
}

model Kudos {
  id          String   @id @default(cuid())
  fromUserId  String
  fromUser    User     @relation("KudosSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId    String
  toUser      User     @relation("KudosReceived", fields: [toUserId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project? @relation("ProjectKudos", fields: [projectId], references: [id], onDelete: SetNull)
  message     String
  createdAt   DateTime @default(now())

  @@index([toUserId])
}

model UserStreak {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation("UserStreaks", fields: [userId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project  @relation("ProjectStreaks", fields: [projectId], references: [id], onDelete: Cascade)
  currentWeeks   Int      @default(0)
  longestWeeks   Int      @default(0)
  lastActivityAt DateTime @default(now())

  @@unique([userId, projectId])
}

model DreamWallPost {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation("DreamPosts", fields: [userId], references: [id], onDelete: Cascade)
  dreamText String
  reactions DreamWallReaction[]
  createdAt DateTime             @default(now())
}

model DreamWallReaction {
  id              String        @id @default(cuid())
  dreamWallPostId String
  dreamWallPost   DreamWallPost @relation(fields: [dreamWallPostId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation("DreamReactions", fields: [userId], references: [id], onDelete: Cascade)
  emoji           String
  createdAt       DateTime      @default(now())

  @@unique([dreamWallPostId, userId, emoji])
}

model ProjectFlag {
  id           String        @id @default(cuid())
  projectId    String
  project      Project       @relation("ProjectFlags", fields: [projectId], references: [id], onDelete: Cascade)
  flaggedById  String
  flaggedBy    User          @relation("FlaggedBy", fields: [flaggedById], references: [id])
  reason       String
  status       String        @default("pending")
  reviewedById String?
  reviewedBy   User?         @relation("FlagReviewer", fields: [reviewedById], references: [id])
  decisionNote String?
  ethicsReview EthicsReview?
  createdAt    DateTime      @default(now())

  @@index([projectId])
}

model EthicsReview {
  id            String      @id @default(cuid())
  projectId     String
  project       Project     @relation("EthicsReviews", fields: [projectId], references: [id], onDelete: Cascade)
  reviewerId    String
  reviewer      User        @relation("EthicsReviewer", fields: [reviewerId], references: [id])
  projectFlagId String?     @unique
  projectFlag   ProjectFlag? @relation(fields: [projectFlagId], references: [id])
  outcome       String
  note          String?
  createdAt     DateTime    @default(now())

  @@index([projectId])
}

model Channel {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation("ProjectChannels", fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  type        String   @default("text")
  order       Int      @default(0)
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())
  messages    ChannelMessage[]
  readMarkers ChannelReadMarker[]

  @@index([projectId])
  @@unique([projectId, name])
}

model ChannelMessage {
  id             String   @id @default(cuid())
  channelId      String
  channel        Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorId       String
  author         User     @relation("ChannelMessages", fields: [authorId], references: [id], onDelete: Cascade)
  body           String   @db.Text
  threadParentId String?
  threadParent   ChannelMessage?  @relation("MessageThread", fields: [threadParentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  threadReplies  ChannelMessage[] @relation("MessageThread")
  reactions      ChannelMessageReaction[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([channelId, createdAt])
  @@index([threadParentId])
}

model ChannelMessageReaction {
  id        String         @id @default(cuid())
  messageId String
  message   ChannelMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation("ChannelReactions", fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime       @default(now())

  @@unique([messageId, userId, emoji])
}

model ChannelReadMarker {
  id         String   @id @default(cuid())
  channelId  String
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("ChannelReadMarkers", fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now())

  @@unique([channelId, userId])
  @@index([userId])
}
